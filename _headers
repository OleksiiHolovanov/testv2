  Content-Security-Policy: default-src 'self'; script-src 'self' https://script.google.com https://script.googleusercontent.com; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src https://script.google.com https://script.googleusercontent.com; object-src 'none'; base-uri 'self'; form-action 'self' https://script.google.com https://script.googleusercontent.com; frame-ancestors 'none'; upgrade-insecure-requests
